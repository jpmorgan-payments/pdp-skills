# JPM Payments API credentials
# Copy this file to .env and fill in your values.
# Do NOT commit .env to source control.

JPM_CLIENT_ID=
JPM_CERT_PATH=
JPM_PRIVATE_KEY_PATH=

# resource_id from your JPM onboarding email (subject usually contains
# "API Entitlements"). Looks like:
#   JPMC:URI:RS-000000-<FID>-HelixAPIEntitlements...
# CAT and PROD have different resource_ids — set the one for the env you target.
JPM_RESOURCE_ID=
